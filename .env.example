DB_USER=treetex
DB_PASSWORD=treetex
DB_NAME=treetex
JWT_SECRET=change-me-to-a-long-random-string
WEB_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Redis — real-time layer (live-stream viewer counts, chat pub/sub, WebSocket adapter)
REDIS_HOST=redis
REDIS_PORT=6379

# S3-compatible object storage (Cloudflare R2, AWS S3, MinIO — any provider works)
# Leave empty to disable media uploads (server logs a warning, /media/presign returns 503)
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=auto
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false
